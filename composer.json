{
    "name": "forecastapi/php-sdk",
    "description": "Time series forecasting service with multiple algorithms and automatic method selection",
    "keywords": [
        "openapitools",
        "openapi-generator",
        "openapi",
        "php",
        "sdk",
        "rest",
        "api"
    ],
    "homepage": "https://openapi-generator.tech",
    "license": "MIT",
    "authors": [
        {
            "name": "ForecastAPI",
            "homepage": "https://forecastapi.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "autoload": {
        "psr-4": { "ForecastAPI\\Sdk\\" : "lib/" }
    },
    "autoload-dev": {
        "psr-4": { "ForecastAPI\\Sdk\\Test\\" : "test/" }
    }
}
